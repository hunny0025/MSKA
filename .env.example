# =============================================================================
# Maruti Suzuki Knowledge Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values. Never commit .env to git.

# --- Application ---
APP_NAME=MarutiSuzukiKnowledgeAssistant
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# --- Database (PostgreSQL) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mskai
POSTGRES_USER=mskai_user
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- JWT / Auth ---
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI Provider ---
# Options: azure_openai | copilot_studio
AI_PROVIDER=azure_openai

# Azure OpenAI (primary recommended)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Copilot Studio Connector (alternative if M365 Copilot licensed)
COPILOT_STUDIO_BOT_ID=
COPILOT_STUDIO_TENANT_ID=
COPILOT_STUDIO_TOKEN_ENDPOINT=

# --- RAG Configuration ---
RAG_CONFIDENCE_THRESHOLD=0.65
RAG_TOP_K=10
RAG_RERANK_TOP_N=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# --- Embedding Model ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- File Storage ---
FILE_STORAGE_PATH=./storage/documents
VECTOR_STORE_PATH=./storage/vectors

# --- PII Scanner ---
PII_SCAN_ENABLED=true

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AI_CALLS_PER_HOUR=100

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Data Residency ---
DATA_RESIDENCY=india
